# Środowisko KSeF: test | demo | prod
KSEF_ENV=test

# NIP podmiotu (10 cyfr)
KSEF_NIP=

# Token autoryzacyjny KSeF (base64) — NIGDY nie commituj!
KSEF_TOKEN=

# Ścieżka do klucza prywatnego PEM (opcjonalnie, do XAdES)
KSEF_KEY_PATH=

# Ścieżka do certyfikatu PEM (opcjonalnie, do XAdES)
KSEF_CERT_PATH=

# Katalog danych (domyślnie: ~/.ksef-mcp)
KSEF_DATA_DIR=

# Tryb zatwierdzania wysyłki: auto | manual (domyślnie: manual)
KSEF_APPROVAL_MODE=manual

# Poziom logów: debug | info | warn | error
KSEF_LOG_LEVEL=info
